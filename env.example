# 서버 설정
PORT=3000
NODE_ENV=development

# JWT 설정
JWT_SECRET=your-super-secret-jwt-key-for-babple-development

# 파일 업로드 설정
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Redis 설정 (캐싱용)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 이메일 설정 (선택사항)
# Gmail 사용 시:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# AWS WorkMail 사용 시 (예시):
# 리전별 SMTP 엔드포인트: smtp.mail.{region}.awsapps.com
# 예: us-east-1 -> smtp.mail.us-east-1.awsapps.com
#     ap-northeast-2 -> smtp.mail.ap-northeast-2.awsapps.com
SMTP_HOST=smtp.mail.ap-northeast-2.awsapps.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=babple.biz@slowflowsoft.com
SMTP_PASS=your_workmail_password
EMAIL_FROM=babple.biz@slowflowsoft.com

# 소셜 로그인 설정 (선택사항)
GOOGLE_CLIENT_ID=your_google_client_id
KAKAO_CLIENT_ID=your_kakao_client_id
NAVER_CLIENT_ID=your_naver_client_id
